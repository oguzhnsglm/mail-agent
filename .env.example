# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Newsletter Configuration
SENDER_EMAIL=your_email@gmail.com
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com
NEWSLETTER_TITLE=Daily AI Newsletter

# Scheduling Configuration
SCHEDULE_TIMES=08:00,18:00
TIMEZONE=Asia/Kolkata

# Crawling Configuration
MAX_ARTICLES_PER_TOPIC=5
CRAWL_TIMEOUT=30

# LLM Configuration
DEFAULT_MODEL=gpt-4-turbo-preview
TEMPERATURE=0.7
MAX_TOKENS=2000

# Social Media Search Configuration
SOCIAL_SEARCH_ENABLED=true
SOCIAL_PLATFORMS=twitter,linkedin
SOCIAL_SEARCH_RECENCY_DAYS=2
SOCIAL_MAX_RESULTS_PER_PLATFORM=3